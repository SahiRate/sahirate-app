# SahiRate Backend — Environment Variables
# Copy this file to backend/.env and fill in real values.

# MongoDB connection string
MONGO_URL="mongodb://localhost:27017"

# Database name used by the app
DB_NAME="test_database"

# Allowed CORS origins (comma-separated). Use "*" for open access in dev.
CORS_ORIGINS="*"

# Emergent Universal LLM key (works for OpenAI / Claude / Gemini via emergentintegrations)
# Get yours from the Emergent platform → Profile → Universal Key
EMERGENT_LLM_KEY="sk-emergent-xxxxxxxxxxxxxxxx"
