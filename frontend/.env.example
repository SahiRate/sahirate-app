# SahiRate Frontend — Environment Variables
# Copy this file to frontend/.env and fill in real values.

# Public backend URL used by the React app for all /api requests.
# For local dev: http://localhost:8001
# For preview / prod: your deployed backend URL (e.g. https://your-app.example.com)
REACT_APP_BACKEND_URL=https://your-backend-domain.example.com

# WebSocket dev server port (leave as-is for Emergent preview)
WDS_SOCKET_PORT=443
