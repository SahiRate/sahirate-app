{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "paths": {
      "@/*": [
        "src/*"
      ]
    },

    "jsx": "react-jsx",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "resolveJsonModule": true,

    "strict": false,

    "skipLibCheck": true
  },

  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}